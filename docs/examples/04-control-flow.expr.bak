// 04-control-flow.expr
// ====================
// This example demonstrates control flow in Express:
// - if/else if/else conditional statements
// - for-in loops (iterate over keys/indices)
// - for-of loops (iterate over values)
//
// Express provides familiar control flow structures with
// a clean, minimal syntax.

func main() {
  // ========== IF/ELSE STATEMENTS ==========
  int temperature = 75

  if temperature > 90 {
    Println("It's hot outside!")
  } else if temperature > 70 {
    Println("The weather is pleasant.")
  } else if temperature > 50 {
    Println("It's a bit chilly.")
  } else {
    Println("It's cold outside!")
  }

  // Single-line if (no braces needed for single statement)
  int x = 10
  if x == 10
    Println("x is exactly 10")

  // Nested conditions
  int age = 25
  bool hasLicense = true

  if age >= 18 {
    if hasLicense {
      Println("You can drive legally.")
    } else {
      Println("You are old enough but need a license.")
    }
  } else {
    Println("You are not old enough to drive.")
  }

  // ========== FOR-IN LOOPS ==========
  // for-in iterates over the keys (indices) of a collection
  Println("\nFor-in loop (indices):")
  for i in [10, 20, 30, 40, 50] {
    Println("Index:", i)
  }

  // ========== FOR-OF LOOPS ==========
  // for-of iterates over the values of a collection
  Println("\nFor-of loop (values):")
  for value of [10, 20, 30, 40, 50] {
    Println("Value:", value)
  }

  // Using for-of with a range
  Println("\nFor-of with range:")
  for n of 1..5 {
    Println("Number:", n)
  }

  // Nested loops
  Println("\nNested loops:")
  for i in [1, 2, 3] {
    for j in [1, 2, 3] {
      Println("(", i, ",", j, ")")
    }
  }
}
